{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ratan",
  "version": "0.1.0",
  "identifier": "com.ratan.app",
  "build": {
    "frontendDist": "../frontend/out",
    "beforeBuildCommand": "npm --prefix frontend run build:export",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://localhost:4500"
  },
  "app": {
    "windows": [
      {
        "title": "Ratan — Print Automation",
        "width": 1320,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": {
      "../MODNet/pretrained/modnet.onnx": "models/modnet.onnx",
      "../models/ultraface-RFB-320.onnx": "models/ultraface-RFB-320.onnx",
      "../dist/SumatraPDF.exe": "SumatraPDF.exe",
      "../dist/whatsapp-sidecar.exe": "whatsapp-sidecar.exe"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OWNER/REPO/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY"
    }
  }
}
