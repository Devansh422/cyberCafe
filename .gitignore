# Dependencies
node_modules/
**/node_modules/

# Environment and local secrets
.env
.env.*
!.env.example
backend/.env

# Logs
*.log
logs/
backend/logs/
frontend/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rust / Tauri build output
target/
src-tauri/target/
src-tauri/gen/
*.pdb

# Next.js build output
.next/
frontend/.next/
frontend/out/

# Release/build artifacts
dist/
build/
*.msi
*.exe
!dist/.gitkeep

# WhatsApp runtime state
.wwebjs_auth/
.wwebjs_cache/
backend/.wwebjs_auth/
backend/.wwebjs_cache/

# Local databases
backend/data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite

# Media center files (keep folder placeholders)
media-center/incoming/*
media-center/processed/*
media-center/printed/*
media-center/failed/*
media-center/temp/*
!media-center/**/.gitkeep

# Local editor / assistant state
.vscode/
.idea/
.claude/
.DS_Store
